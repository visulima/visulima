        "zod": "^3.25.76"
    },
    "peerDependencies": {
        "@hapi/hapi": "catalog:peer",
        "@koa/router": "catalog:backend",
        "@visulima/crud": "workspace:*",
        "chalk": "catalog:peer",
        "commander": "catalog:peer",
        "cors": "catalog:peer",
        "express": "^4.22.1",
        "fastify": "catalog:backend",
        "koa": "catalog:backend",
        "next": "catalog:peer",
        "rate-limiter-flexible": "catalog:peer",
        "react": "catalog:frontend",
        "react-dom": "catalog:frontend",
        "redoc": "catalog:peer",
        "swagger-ui-dist": "catalog:peer",
        "swagger-ui-react": "catalog:frontend",
        "webpack": "catalog:build",
        "zod": "^3"
    },
