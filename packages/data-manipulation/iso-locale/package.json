{
    "name": "@visulima/iso-locale",
    "version": "1.0.0-alpha.11",
    "description": "ISO data for countries, currencies, regions, timezones, and BCP 47 locale support.",
    "keywords": [
        "alpha-2",
        "alpha-3",
        "bcp-47",
        "bcp47",
        "calling-code",
        "continent",
        "continents",
        "countries",
        "country",
        "country-codes",
        "currencies",
        "currency",
        "currency-codes",
        "emoji",
        "flag",
        "flag-emoji",
        "geoscheme",
        "i18n",
        "iana",
        "iana-timezone",
        "internationalization",
        "iso",
        "iso-3166",
        "iso-3166-1",
        "iso-4217",
        "iso-639",
        "iso-639-1",
        "iso-639-3",
        "language-tag",
        "language-tags",
        "locale",
        "locales",
        "numeric-code",
        "phone-code",
        "regions",
        "subregion",
        "subregions",
        "timezone",
        "timezones",
        "un-geoscheme",
        "visulima"
    ],
    "homepage": "https://visulima.com/packages/iso-locale",
    "bugs": "https://github.com/visulima/visulima/issues",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/data-manipulation/iso-locale"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./countries": {
            "types": "./dist/countries.d.ts",
            "default": "./dist/countries.js"
        },
        "./currencies": {
            "types": "./dist/currencies.d.ts",
            "default": "./dist/currencies.js"
        },
        "./locale": {
            "types": "./dist/locale.d.ts",
            "default": "./dist/locale.js"
        },
        "./regions": {
            "types": "./dist/regions.d.ts",
            "default": "./dist/regions.js"
        },
        "./timezones": {
            "types": "./dist/timezones.d.ts",
            "default": "./dist/timezones.js"
        },
        "./types": {
            "types": "./dist/types.d.ts",
            "default": "./dist/types.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack --profile esm-only",
        "lint:eslint": "eslint .",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit --project tsconfig.json",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/node": "catalog:types",
        "@visulima/packem": "catalog:dev",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "prettier": "catalog:lint",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test"
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
