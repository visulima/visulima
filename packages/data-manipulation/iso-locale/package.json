{
    "name": "@visulima/iso-locale",
    "version": "1.0.0-alpha.2",
    "description": "ISO data for countries, currencies, regions, timezones, and BCP 47 locale support.",
    "keywords": [
        "visulima",
        "iso",
        "iso-3166",
        "iso-3166-1",
        "iso-4217",
        "iso-639",
        "iso-639-1",
        "iso-639-3",
        "country",
        "countries",
        "currency",
        "currencies",
        "country-codes",
        "currency-codes",
        "internationalization",
        "i18n",
        "locale",
        "locales",
        "bcp47",
        "bcp-47",
        "language-tag",
        "language-tags",
        "timezone",
        "timezones",
        "iana",
        "iana-timezone",
        "regions",
        "geoscheme",
        "un-geoscheme",
        "continent",
        "continents",
        "subregion",
        "subregions",
        "alpha-2",
        "alpha-3",
        "numeric-code",
        "calling-code",
        "phone-code",
        "flag",
        "emoji",
        "flag-emoji"
    ],
    "homepage": "https://visulima.com/packages/iso-locale",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/data-manipulation/iso-locale"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./countries": {
            "types": "./dist/countries.d.ts",
            "default": "./dist/countries.js"
        },
        "./currencies": {
            "types": "./dist/currencies.d.ts",
            "default": "./dist/currencies.js"
        },
        "./locale": {
            "types": "./dist/locale.d.ts",
            "default": "./dist/locale.js"
        },
        "./regions": {
            "types": "./dist/regions.d.ts",
            "default": "./dist/regions.js"
        },
        "./timezones": {
            "types": "./dist/timezones.d.ts",
            "default": "./dist/timezones.js"
        },
        "./types": {
            "types": "./dist/types.d.ts",
            "default": "./dist/types.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint .",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=.prettierrc.cjs --check .",
        "lint:prettier:fix": "prettier --config=.prettierrc.cjs --write .",
        "lint:types": "tsc --noEmit --project tsconfig.json",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "^22.0.2",
        "@anolilab/semantic-release-pnpm": "5.0.0",
        "@anolilab/semantic-release-preset": "13.1.1",
        "@arethetypeswrong/cli": "^0.18.2",
        "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
        "@total-typescript/ts-reset": "^0.6.1",
        "@types/node": "25.3.3",
        "@visulima/packem": "2.0.0-alpha.48",
        "@vitest/coverage-v8": "^4.0.18",
        "@vitest/ui": "^4.0.18",
        "conventional-changelog-conventionalcommits": "9.3.0",
        "esbuild": "^0.27.3",
        "eslint": "10.0.2",
        "prettier": "^3.8.1",
        "publint": "^0.3.18",
        "rimraf": "^6.1.3",
        "secretlint": "11.3.1",
        "semantic-release": "^25.0.3",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=22.21 <=25.*"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
