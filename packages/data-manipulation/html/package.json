{
    "name": "@visulima/html",
    "version": "1.0.0-alpha.4",
    "description": "Functions for HTML, such as escaping or unescaping HTML entities",
    "keywords": [
        "visulima",
        "html",
        "escape",
        "escaping",
        "escape-html",
        "escape-css",
        "escape-js",
        "sanitize",
        "sanitization",
        "sanitize-html",
        "strip",
        "strip-html",
        "xss",
        "security",
        "entities",
        "html-entities",
        "css",
        "javascript",
        "js",
        "template",
        "template-tag",
        "validation",
        "custom-element",
        "typescript"
    ],
    "homepage": "https://visulima.com/packages/html",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/html"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint .",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=.prettierrc.cjs --check .",
        "lint:prettier:fix": "prettier --config=.prettierrc.cjs --write .",
        "lint:types": "tsc --noEmit --project tsconfig.json",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "csstype": "3.2.3",
        "sanitize-html": "2.17.1"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "^22.0.2",
        "@anolilab/semantic-release-pnpm": "5.0.0",
        "@anolilab/semantic-release-preset": "13.1.1",
        "@arethetypeswrong/cli": "^0.18.2",
        "@optimize-lodash/rollup-plugin": "6.0.0",
        "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
        "@std/html": "jsr:@std/html@1.0.5",
        "@total-typescript/ts-reset": "^0.6.1",
        "@types/node": "25.3.3",
        "@types/sanitize-html": "2.16.0",
        "@visulima/packem": "2.0.0-alpha.54",
        "@vitest/coverage-v8": "^4.0.18",
        "@vitest/ui": "^4.0.18",
        "conventional-changelog-conventionalcommits": "9.3.0",
        "esbuild": "^0.27.3",
        "eslint": "10.0.2",
        "html-entities": "2.6.0",
        "html-tags": "^5.1.0",
        "is-html": "^3.2.0",
        "prettier": "^3.8.1",
        "publint": "^0.3.18",
        "rimraf": "^6.1.3",
        "secretlint": "11.3.1",
        "semantic-release": "^25.0.3",
        "string-strip-html": "^13.5.3",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=22.13 <=25.*"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
