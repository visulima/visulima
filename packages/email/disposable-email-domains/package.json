{
    "name": "@visulima/disposable-email-domains",
    "version": "1.0.0-alpha.13",
    "description": "A regularly updated list of disposable and temporary email domains.",
    "keywords": [
        "visulima",
        "disposable-email-domains",
        "disposable-email",
        "temporary-email",
        "email-validation",
        "email-domains",
        "email-list",
        "spam-prevention"
    ],
    "homepage": "https://visulima.com/packages/disposable-email-domains",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/email/disposable-email-domains"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./domains": {
            "default": "./dist/domains.json"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "packem build --development && pnpm run generate:domains",
        "build:prod": "packem build --production && pnpm run generate:domains",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "generate:domains": "node ./scripts/sync-domains.js",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint .",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit --project tsconfig.json",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/node": "catalog:types",
        "@visulima/packem": "catalog:dev",
        "@visulima/tabular": "4.0.0-alpha.11",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "email-providers": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "prettier": "catalog:lint",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test"
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
