{
    "name": "@visulima/email-verifier",
    "version": "1.0.0",
    "description": "Mailer-free email address verification and enrichment: syntax, MX/SMTP probing, disposable/free/role detection, catch-all, provider & secure-email-gateway classification, typo suggestions, and a 0–100 quality score.",
    "keywords": [
        "accept-all",
        "catch-all",
        "disposable-email",
        "email-enrichment",
        "email-quality-score",
        "email-validation",
        "email-verification",
        "free-email",
        "mx-records",
        "role-account",
        "secure-email-gateway",
        "smtp-verification",
        "visulima"
    ],
    "homepage": "https://visulima.com/packages/email-verifier",
    "bugs": "https://github.com/visulima/visulima/issues",
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/email/email-verifier"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./verify-email": {
            "types": "./dist/verify-email.d.ts",
            "default": "./dist/verify-email.js"
        },
        "./score": {
            "types": "./dist/score.d.ts",
            "default": "./dist/score.js"
        },
        "./checks/syntax": {
            "types": "./dist/checks/syntax.d.ts",
            "default": "./dist/checks/syntax.js"
        },
        "./checks/mx": {
            "types": "./dist/checks/mx.d.ts",
            "default": "./dist/checks/mx.js"
        },
        "./checks/smtp": {
            "types": "./dist/checks/smtp.d.ts",
            "default": "./dist/checks/smtp.js"
        },
        "./checks/disposable": {
            "types": "./dist/checks/disposable.d.ts",
            "default": "./dist/checks/disposable.js"
        },
        "./checks/free": {
            "types": "./dist/checks/free.d.ts",
            "default": "./dist/checks/free.js"
        },
        "./checks/role": {
            "types": "./dist/checks/role.d.ts",
            "default": "./dist/checks/role.js"
        },
        "./checks/tag": {
            "types": "./dist/checks/tag.d.ts",
            "default": "./dist/checks/tag.js"
        },
        "./checks/character": {
            "types": "./dist/checks/character.d.ts",
            "default": "./dist/checks/character.js"
        },
        "./checks/symbol": {
            "types": "./dist/checks/symbol.d.ts",
            "default": "./dist/checks/symbol.js"
        },
        "./enrich/provider": {
            "types": "./dist/enrich/provider.d.ts",
            "default": "./dist/enrich/provider.js"
        },
        "./enrich/typo": {
            "types": "./dist/enrich/typo.d.ts",
            "default": "./dist/enrich/typo.js"
        },
        "./enrich/name": {
            "types": "./dist/enrich/name.d.ts",
            "default": "./dist/enrich/name.js"
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack --profile esm-only",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit --project tsconfig.json",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@visulima/disposable-email-domains": "1.0.0",
        "@visulima/email-provider-mx": "1.0.0",
        "@visulima/free-email-domains": "1.0.0",
        "lru-cache": "catalog:prod"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/prettier-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/node": "catalog:types",
        "@visulima/packem": "catalog:dev",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "prettier": "catalog:lint",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test"
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    }
}
