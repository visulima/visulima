{
    "name": "@visulima/task-runner",
    "version": "0.0.1",
    "description": "A task runner with caching support for monorepo workspaces",
    "keywords": [
        "visulima",
        "task-runner",
        "cache",
        "monorepo",
        "task",
        "runner",
        "workspace"
    ],
    "homepage": "https://visulima.com/packages/task-runner",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/task-runner"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "*.node",
        "README.md",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:native": "napi build --platform --release --cargo-cwd native",
        "build:native:debug": "napi build --platform --cargo-cwd native",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache *.node",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=.prettierrc.cjs --check .",
        "lint:prettier:fix": "prettier --config=.prettierrc.cjs --write .",
        "lint:types": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@visulima/humanizer": "workspace:*",
        "@visulima/path": "workspace:*"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "^16.4.4",
        "@anolilab/prettier-config": "^6.0.8",
        "@anolilab/semantic-release-pnpm": "3.0.0",
        "@anolilab/semantic-release-preset": "^12.0.0",
        "@arethetypeswrong/cli": "^0.18.2",
        "@napi-rs/cli": "^3.0.0-alpha.72",
        "@secretlint/secretlint-rule-preset-recommend": "^11.2.5",
        "@total-typescript/ts-reset": "^0.6.1",
        "@types/node": "24.10.1",
        "@visulima/packem": "2.0.0-alpha.37",
        "@vitest/coverage-v8": "^4.0.13",
        "@vitest/ui": "^4.0.13",
        "conventional-changelog-conventionalcommits": "9.1.0",
        "esbuild": "^0.27.0",
        "eslint": "9.39.1",
        "prettier": "^3.6.2",
        "publint": "^0.3.15",
        "rimraf": "^6.1.2",
        "secretlint": "11.2.5",
        "semantic-release": "^25.0.2",
        "typescript": "^5.9.3",
        "vitest": "^4.0.13"
    },
    "optionalDependencies": {
        "@visulima/task-runner-binding-darwin-arm64": "0.0.1",
        "@visulima/task-runner-binding-darwin-x64": "0.0.1",
        "@visulima/task-runner-binding-linux-arm64-gnu": "0.0.1",
        "@visulima/task-runner-binding-linux-arm64-musl": "0.0.1",
        "@visulima/task-runner-binding-linux-x64-gnu": "0.0.1",
        "@visulima/task-runner-binding-linux-x64-musl": "0.0.1",
        "@visulima/task-runner-binding-win32-arm64-msvc": "0.0.1",
        "@visulima/task-runner-binding-win32-x64-msvc": "0.0.1"
    },
    "engines": {
        "node": ">=20.19 <=25.x"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "napi": {
        "binaryName": "task-runner-native",
        "packageName": "@visulima/task-runner-binding",
        "targets": [
            "x86_64-apple-darwin",
            "aarch64-apple-darwin",
            "x86_64-unknown-linux-gnu",
            "x86_64-unknown-linux-musl",
            "aarch64-unknown-linux-gnu",
            "aarch64-unknown-linux-musl",
            "x86_64-pc-windows-msvc",
            "aarch64-pc-windows-msvc"
        ]
    }
}
