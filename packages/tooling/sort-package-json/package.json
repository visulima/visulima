{
    "name": "@visulima/sort-package-json",
    "version": "1.0.0-alpha.1",
    "description": "Fast package.json sorter powered by Rust via NAPI with JavaScript fallback",
    "keywords": [
        "visulima",
        "sort-package-json",
        "package-json",
        "sort",
        "formatter",
        "napi",
        "rust"
    ],
    "homepage": "https://visulima.com/packages/sort-package-json",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/tooling/sort-package-json"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**",
        "index.js",
        "README.md",
        "CHANGELOG.md",
        "LICENSE.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:native": "napi build --platform --release --manifest-path native/Cargo.toml --output-dir . --js index.js",
        "build:native:debug": "napi build --platform --manifest-path native/Cargo.toml --output-dir . --js index.js",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache *.node",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=.prettierrc.cjs --check .",
        "lint:prettier:fix": "prettier --config=.prettierrc.cjs --write .",
        "lint:types": "tsc --noEmit",
        "test": "vitest run",
        "test:bench": "vitest bench",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "sort-package-json": "catalog:dev"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/prettier-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@napi-rs/cli": "catalog:dev",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@semantic-release/exec": "catalog:dev",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/node": "catalog:types",
        "@visulima/packem": "catalog:dev",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "prettier": "catalog:lint",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test"
    },
    "optionalDependencies": {
        "@visulima/sort-package-json-binding-darwin-arm64": "workspace:*",
        "@visulima/sort-package-json-binding-darwin-x64": "workspace:*",
        "@visulima/sort-package-json-binding-linux-arm64-gnu": "workspace:*",
        "@visulima/sort-package-json-binding-linux-arm64-musl": "workspace:*",
        "@visulima/sort-package-json-binding-linux-x64-gnu": "workspace:*",
        "@visulima/sort-package-json-binding-linux-x64-musl": "workspace:*",
        "@visulima/sort-package-json-binding-win32-arm64-msvc": "workspace:*",
        "@visulima/sort-package-json-binding-win32-x64-msvc": "workspace:*"
    },
    "engines": {
        "node": ">=20.19 <=25.x"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "napi": {
        "binaryName": "sort-package-json-native",
        "packageName": "@visulima/sort-package-json-binding",
        "targets": [
            "x86_64-apple-darwin",
            "aarch64-apple-darwin",
            "x86_64-unknown-linux-gnu",
            "x86_64-unknown-linux-musl",
            "aarch64-unknown-linux-gnu",
            "aarch64-unknown-linux-musl",
            "x86_64-pc-windows-msvc",
            "aarch64-pc-windows-msvc"
        ]
    }
}
