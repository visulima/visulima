{
    "name": "@visulima/vis",
    "version": "1.0.0-alpha.8",
    "description": "A CLI task runner for monorepo workspaces, powered by @visulima/task-runner",
    "keywords": [
        "visulima",
        "vis",
        "cli",
        "task-runner",
        "monorepo",
        "workspace",
        "build",
        "cache"
    ],
    "homepage": "https://visulima.com/packages/vis",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/tooling/vis"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        "./config": {
            "types": "./dist/config.d.ts",
            "default": "./dist/config.js"
        },
        "./generate": {
            "types": "./dist/generate/index.d.ts",
            "default": "./dist/generate/index.js"
        },
        "./schemas/project.schema.json": "./schemas/project.schema.json",
        "./schemas/vis-config.schema.json": "./schemas/vis-config.schema.json",
        "./package.json": "./package.json"
    },
    "bin": {
        "v": "./dist/bin.js",
        "vis": "./dist/bin.js"
    },
    "files": [
        "dist/**",
        "schemas/**",
        "index.js",
        "README.md",
        "CHANGELOG.md",
        "LICENSE.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:native": "napi build --platform --release --esm --manifest-path native/Cargo.toml --output-dir . --js index.js",
        "build:native:debug": "napi build --platform --esm --manifest-path native/Cargo.toml --output-dir . --js index.js",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache *.node",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@bomb.sh/tab": "catalog:dev",
        "@nkzw/safe-word-list": "^3.1.2",
        "@socketsecurity/registry": "^2.0.2",
        "@visulima/ansi": "4.0.0-alpha.13",
        "@visulima/cerebro": "3.0.0-alpha.11",
        "@visulima/colorize": "2.0.0-alpha.10",
        "@visulima/find-ai-runner": "1.0.0-alpha.5",
        "@visulima/find-cache-dir": "3.0.0-alpha.9",
        "@visulima/fs": "5.0.0-alpha.12",
        "@visulima/humanizer": "3.0.0-alpha.11",
        "@visulima/package": "5.0.0-alpha.11",
        "@visulima/path": "3.0.0-alpha.10",
        "@visulima/secret-scanner": "1.0.0-alpha.1",
        "@visulima/string": "3.0.0-alpha.11",
        "@visulima/task-runner": "1.0.0-alpha.7",
        "@visulima/tui": "1.0.0-alpha.4",
        "execa": "catalog:dev",
        "giget": "^3.2.0",
        "hookable": "^6.1.1",
        "jiti": "catalog:dev",
        "jstoxml": "catalog:prod",
        "module-replacements": "^2.11.0",
        "module-replacements-codemods": "^1.2.1",
        "react": "catalog:frontend",
        "react-reconciler": ">=0.33.0",
        "semver": "^7.7.4",
        "smol-toml": "catalog:peer",
        "validate-npm-package-name": "^7.0.2",
        "yaml": "catalog:prod",
        "zeptomatch": "catalog:dev"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/prettier-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@eslint-react/eslint-plugin": "catalog:lint",
        "@napi-rs/cli": "catalog:dev",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@semantic-release/exec": "catalog:dev",
        "@shared/xxh3": "workspace:*",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/jstoxml": "catalog:types",
        "@types/node": "catalog:types",
        "@types/react": "catalog:types",
        "@types/react-reconciler": "catalog:types",
        "@types/semver": "^7.7.1",
        "@types/validate-npm-package-name": "^4.0.2",
        "@visulima/packem": "catalog:dev",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "ajv": "catalog:dev",
        "ajv-formats": "catalog:dev",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "eslint-plugin-jsx-a11y": "6.10.2",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.1.0",
        "eslint-plugin-react-perf": "3.3.3",
        "eslint-plugin-react-refresh": "0.5.2",
        "eslint-plugin-react-you-might-not-need-an-effect": "0.9.3",
        "eslint-plugin-validate-jsx-nesting": "0.1.1",
        "is-in-ci": "2.0.0",
        "prettier": "catalog:lint",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test"
    },
    "optionalDependencies": {
        "@visulima/vis-binding-darwin-arm64": "workspace:*",
        "@visulima/vis-binding-darwin-x64": "workspace:*",
        "@visulima/vis-binding-linux-arm64-gnu": "workspace:*",
        "@visulima/vis-binding-linux-arm64-musl": "workspace:*",
        "@visulima/vis-binding-linux-x64-gnu": "workspace:*",
        "@visulima/vis-binding-linux-x64-musl": "workspace:*",
        "@visulima/vis-binding-win32-arm64-msvc": "workspace:*",
        "@visulima/vis-binding-win32-x64-msvc": "workspace:*"
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "napi": {
        "binaryName": "vis-native",
        "packageName": "@visulima/vis-binding",
        "targets": [
            "x86_64-apple-darwin",
            "aarch64-apple-darwin",
            "x86_64-unknown-linux-gnu",
            "x86_64-unknown-linux-musl",
            "aarch64-unknown-linux-gnu",
            "aarch64-unknown-linux-musl",
            "x86_64-pc-windows-msvc",
            "aarch64-pc-windows-msvc"
        ]
    }
}
