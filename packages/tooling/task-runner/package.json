{
    "name": "@visulima/task-runner",
    "version": "1.0.0",
    "description": "A task runner with caching support for monorepo workspaces",
    "keywords": [
        "cache",
        "monorepo",
        "runner",
        "task",
        "task-runner",
        "visulima",
        "workspace"
    ],
    "homepage": "https://visulima.com/packages/task-runner",
    "bugs": "https://github.com/visulima/visulima/issues",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/tooling/task-runner"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./cache": {
            "types": "./dist/cache/index.d.ts",
            "default": "./dist/cache/index.js"
        },
        "./concurrent": {
            "types": "./dist/concurrent/index.d.ts",
            "default": "./dist/concurrent/index.js"
        },
        "./graph": {
            "types": "./dist/graph/index.d.ts",
            "default": "./dist/graph/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**",
        "index.js",
        "README.md",
        "CHANGELOG.md",
        "LICENSE.md"
    ],
    "scripts": {
        "bench:native": "cargo bench --manifest-path native/Cargo.toml",
        "build": "packem build --development",
        "build:native": "napi build --platform --release --esm --manifest-path native/Cargo.toml --output-dir . --js index.js",
        "build:native:debug": "napi build --platform --esm --manifest-path native/Cargo.toml --output-dir . --js index.js",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache *.node",
        "dev": "pnpm run build --watch",
        "fallow:audit": "fallow audit",
        "fallow:dead-code": "fallow dead-code",
        "fallow:health": "fallow health --report-only",
        "lint:attw": "attw --pack --profile esm-only",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@lydell/node-pty": "catalog:dev",
        "@visulima/humanizer": "3.0.0",
        "@visulima/path": "3.0.0",
        "nanotar": "catalog:node"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/prettier-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@grpc/grpc-js": "1.14.4",
        "@grpc/proto-loader": "0.8.1",
        "@napi-rs/cli": "catalog:dev",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@semantic-release/exec": "catalog:dev",
        "@shared/xxh3": "workspace:*",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/node": "catalog:types",
        "@visulima/packem": "catalog:dev",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "fallow": "catalog:lint",
        "prettier": "catalog:lint",
        "protobufjs": "8.6.3",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test"
    },
    "peerDependencies": {
        "@grpc/grpc-js": "*",
        "@grpc/proto-loader": "*"
    },
    "peerDependenciesMeta": {
        "@grpc/grpc-js": {
            "optional": true
        },
        "@grpc/proto-loader": {
            "optional": true
        }
    },
    "optionalDependencies": {
        "@visulima/task-runner-binding-darwin-arm64": "workspace:*",
        "@visulima/task-runner-binding-darwin-x64": "workspace:*",
        "@visulima/task-runner-binding-linux-arm64-gnu": "workspace:*",
        "@visulima/task-runner-binding-linux-arm64-musl": "workspace:*",
        "@visulima/task-runner-binding-linux-x64-gnu": "workspace:*",
        "@visulima/task-runner-binding-linux-x64-musl": "workspace:*",
        "@visulima/task-runner-binding-win32-arm64-msvc": "workspace:*",
        "@visulima/task-runner-binding-win32-x64-msvc": "workspace:*"
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "napi": {
        "binaryName": "task-runner-native",
        "packageName": "@visulima/task-runner-binding",
        "targets": [
            "x86_64-apple-darwin",
            "aarch64-apple-darwin",
            "x86_64-unknown-linux-gnu",
            "x86_64-unknown-linux-musl",
            "aarch64-unknown-linux-gnu",
            "aarch64-unknown-linux-musl",
            "x86_64-pc-windows-msvc",
            "aarch64-pc-windows-msvc"
        ]
    }
}
