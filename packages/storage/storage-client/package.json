{
    "name": "@visulima/storage-client",
    "version": "1.0.0-alpha.14",
    "description": "The upload client library. Simple and easy file uploads for React | Vue | Solid | Svelte.",
    "keywords": [
        "abort-upload",
        "batch-upload",
        "chunked-upload",
        "file-management",
        "file-upload",
        "multipart-upload",
        "progress-tracking",
        "react",
        "react-query",
        "resumable-upload",
        "retry",
        "solid",
        "solid-query",
        "storage-client",
        "svelte",
        "svelte-query",
        "tanstack-query",
        "tus",
        "upload",
        "upload-client",
        "visulima",
        "vue",
        "vue-query"
    ],
    "homepage": "https://visulima.com/packages/storage-client",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/storage/storage-client"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./react": {
            "types": "./dist/react/index.d.ts",
            "default": "./dist/react/index.js"
        },
        "./vue": {
            "types": "./dist/vue/index.d.ts",
            "default": "./dist/vue/index.js"
        },
        "./solid": {
            "types": "./dist/solid/index.d.ts",
            "default": "./dist/solid/index.js"
        },
        "./svelte": {
            "types": "./dist/svelte/index.d.ts",
            "default": "./dist/svelte/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack --profile esm-only",
        "lint:eslint": "eslint .",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit --project tsconfig.json",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@eslint-react/eslint-plugin": "catalog:lint",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@sveltejs/vite-plugin-svelte": "catalog:build",
        "@tanstack/eslint-plugin-query": "catalog:lint",
        "@tanstack/react-query": ">=5.100.10",
        "@tanstack/solid-query": "5.100.10",
        "@tanstack/svelte-query": ">=6.1.29",
        "@tanstack/vue-query": ">=5.100.10",
        "@testing-library/react": "catalog:test",
        "@testing-library/svelte": "catalog:test",
        "@testing-library/vue": "catalog:test",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/node": "catalog:types",
        "@types/react": "catalog:types",
        "@typescript-eslint/parser": "catalog:lint",
        "@visulima/packem": "catalog:dev",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "eslint-plugin-jsx-a11y": "catalog:lint",
        "eslint-plugin-react": "catalog:lint",
        "eslint-plugin-react-hooks": "catalog:lint",
        "eslint-plugin-react-perf": "catalog:lint",
        "eslint-plugin-react-refresh": "catalog:lint",
        "eslint-plugin-react-you-might-not-need-an-effect": "catalog:lint",
        "eslint-plugin-solid": "catalog:lint",
        "eslint-plugin-svelte": "catalog:lint",
        "eslint-plugin-testing-library": "catalog:lint",
        "eslint-plugin-validate-jsx-nesting": "catalog:lint",
        "eslint-plugin-vue": "catalog:lint",
        "happy-dom": "catalog:dev",
        "prettier": "catalog:lint",
        "publint": "catalog:dev",
        "react": "catalog:frontend",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "solid-js": ">=1.9.13",
        "svelte": ">=5.54.1",
        "svelte-eslint-parser": "catalog:lint",
        "svelte-preprocess": "catalog:frontend",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test",
        "vue": ">=3.5.34",
        "vue-eslint-parser": "catalog:lint"
    },
    "peerDependencies": {
        "@tanstack/react-query": ">=5.100.9",
        "@tanstack/solid-query": ">=5.100.9",
        "@tanstack/svelte-query": ">=6.1.28",
        "@tanstack/vue-query": ">=5.100.9",
        "react": ">=19.2.6",
        "solid-js": ">=1.9.12",
        "svelte": ">=3.0.0",
        "vue": ">=3.5.34"
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
