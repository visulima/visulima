{
    "name": "@visulima/inspector",
    "version": "2.0.0-alpha.10",
    "description": "Inspect utility for Node.js and Browsers.",
    "keywords": [
        "dump",
        "inspect",
        "inspector",
        "object",
        "pretty",
        "stringify",
        "util.inspect",
        "var-dump",
        "vardump",
        "visulima"
    ],
    "homepage": "https://visulima.com/packages/inspector",
    "bugs": "https://github.com/visulima/visulima/issues",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/error-debugging/inspector"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            },
            "browser": "./dist/index.mjs"
        },
        "./package.json": "./package.json"
    },
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "browser": "./dist/index.mjs",
    "types": "dist/index.d.ts",
    "typesVersions": {
        ">=5.0": {
            ".": [
                "./dist/index.d.ts"
            ]
        }
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:types": "tsc --noEmit",
        "test": "vitest run",
        "test:browser:chrome": "vitest run --browser.name=chromium --browser.headless=true --browser.provider=playwright",
        "test:browser:firefox": "vitest run --browser.name=firefox --browser.headless=true --browser.provider=playwright",
        "test:browser:webkit": "vitest run --browser.name=webkit --browser.headless=true --browser.provider=playwright",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest",
        "ts:coverage": "typescript-coverage-report"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/node": "catalog:types",
        "@visulima/colorize": "2.0.0-alpha.11",
        "@visulima/packem": "catalog:dev",
        "@vitest/browser": "catalog:test",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "eslint-plugin-playwright": "catalog:test",
        "playwright": "catalog:test",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "type-fest": "catalog:dev",
        "typescript": "catalog:tsc",
        "typescript-coverage-report": "catalog:dev",
        "vitest": "catalog:test",
        "webdriverio": "catalog:dev"
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
