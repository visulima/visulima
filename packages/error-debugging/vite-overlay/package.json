{
    "name": "@visulima/vite-overlay",
    "version": "2.0.0-alpha.23",
    "description": "Improved vite overlay",
    "keywords": [
        "error-handling",
        "error-overlay",
        "overlay",
        "react",
        "source-map",
        "svelte",
        "typescript",
        "visulima",
        "vite",
        "vite-error-overlay",
        "vite-overlay",
        "vite-plugin",
        "vue"
    ],
    "homepage": "https://visulima.com/packages/vite-overlay",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/error-debugging/vite-overlay"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:debug": "playwright test --debug",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:ui": "playwright test --ui",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@shikijs/cli": "catalog:prod",
        "@shikijs/langs": "catalog:prod",
        "@visulima/error": "6.0.0-alpha.21",
        "fastest-levenshtein": "catalog:prod",
        "shiki": "catalog:syntax"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/prettier-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@eslint/css": "catalog:lint",
        "@jridgewell/trace-mapping": "catalog:dev",
        "@playwright/test": "catalog:test",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@shikijs/themes": "catalog:dev",
        "@tailwindcss/forms": "catalog:frontend",
        "@tailwindcss/node": "catalog:frontend",
        "@tailwindcss/oxide": "catalog:frontend",
        "@tailwindcss/typography": "catalog:style",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/hast": "catalog:types",
        "@types/node": "catalog:types",
        "@visulima/packem": "catalog:dev",
        "@visulima/path": "3.0.0-alpha.10",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "cssnano": "catalog:dev",
        "csstype": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "hast": "catalog:dev",
        "lucide-static": "catalog:icons",
        "marked": "catalog:dev",
        "prettier": "catalog:lint",
        "prettier-plugin-tailwindcss": "catalog:lint",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "tailwind-csstree": "catalog:dev",
        "tailwindcss": "catalog:style",
        "typescript": "catalog:tsc",
        "vite": "catalog:build",
        "vitest": "catalog:test"
    },
    "peerDependencies": {
        "vite": "^6 || ^7 || ^8"
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    }
}
