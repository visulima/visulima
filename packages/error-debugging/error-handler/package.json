{
    "name": "@visulima/error-handler",
    "version": "2.0.0-alpha.13",
    "description": "Error handlers for use in development and production environments.",
    "keywords": [
        "anolilab",
        "cli",
        "code-frame",
        "codeframe",
        "connect",
        "content-negotiation",
        "debugging",
        "devtools",
        "diagnostics",
        "error",
        "error-handler",
        "error-handlers",
        "error-reporting",
        "exception",
        "express",
        "html-error",
        "http-errors",
        "json-api",
        "jsonapi",
        "jsonp",
        "middleware",
        "node",
        "problem-json",
        "rfc7807",
        "source-code-preview",
        "stacktrace",
        "visulima",
        "whoops",
        "xml",
        "youch"
    ],
    "homepage": "https://visulima.com/packages/error-handler",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/error-debugging/error-handler"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./handler/cli": {
            "types": "./dist/handler/cli-handler.d.ts",
            "default": "./dist/handler/cli-handler.js"
        },
        "./handler/http/node": {
            "types": "./dist/handler/http/node-handler.d.ts",
            "default": "./dist/handler/http/node-handler.js"
        },
        "./handler/http/hono": {
            "types": "./dist/handler/http/fetch-handler.d.ts",
            "default": "./dist/handler/http/fetch-handler.js"
        },
        "./handler/http/bun": {
            "types": "./dist/handler/http/fetch-handler.d.ts",
            "default": "./dist/handler/http/fetch-handler.js"
        },
        "./handler/http/cloudflare": {
            "types": "./dist/handler/http/fetch-handler.d.ts",
            "default": "./dist/handler/http/fetch-handler.js"
        },
        "./handler/http/deno": {
            "types": "./dist/handler/http/fetch-handler.d.ts",
            "default": "./dist/handler/http/fetch-handler.js"
        },
        "./handler/http/edge": {
            "types": "./dist/handler/http/fetch-handler.d.ts",
            "default": "./dist/handler/http/fetch-handler.js"
        },
        "./handler/fetch": {
            "types": "./dist/handler/http/fetch-handler.d.ts",
            "default": "./dist/handler/http/fetch-handler.js"
        },
        "./error-handler/html": {
            "types": "./dist/error-handler/html-error-handler.d.ts",
            "default": "./dist/error-handler/html-error-handler.js"
        },
        "./error-handler/problem": {
            "types": "./dist/error-handler/problem-error-handler.d.ts",
            "default": "./dist/error-handler/problem-error-handler.js"
        },
        "./error-handler/jsonapi": {
            "types": "./dist/error-handler/jsonapi-error-handler.d.ts",
            "default": "./dist/error-handler/jsonapi-error-handler.js"
        },
        "./error-handler/text": {
            "types": "./dist/error-handler/text-error-handler.d.ts",
            "default": "./dist/error-handler/text-error-handler.js"
        },
        "./error-handler/json": {
            "types": "./dist/error-handler/json-error-handler.d.ts",
            "default": "./dist/error-handler/json-error-handler.js"
        },
        "./error-handler/jsonp": {
            "types": "./dist/error-handler/jsonp-error-handler.d.ts",
            "default": "./dist/error-handler/jsonp-error-handler.js"
        },
        "./error-handler/xml": {
            "types": "./dist/error-handler/xml-error-handler.d.ts",
            "default": "./dist/error-handler/xml-error-handler.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@tinyhttp/accepts": "catalog:prod",
        "@visulima/boxen": "3.0.0-alpha.10",
        "@visulima/error": "6.0.0-alpha.14",
        "http-errors": "catalog:prod",
        "http-status-codes": "catalog:prod",
        "jstoxml": "catalog:prod",
        "ts-japi": "catalog:prod"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/http-errors": "catalog:types",
        "@types/node": "catalog:types",
        "@visulima/packem": "catalog:dev",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "node-mocks-http": "catalog:dev",
        "prettier": "catalog:lint",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test"
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
