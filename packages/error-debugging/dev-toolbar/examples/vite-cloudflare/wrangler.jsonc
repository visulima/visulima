{
    // Cloudflare Workers / Pages configuration
    // https://developers.cloudflare.com/workers/wrangler/configuration/
    "name": "dev-toolbar-cloudflare",
    "compatibility_date": "2025-01-01",
    "compatibility_flags": ["nodejs_compat"],
    "main": "./src/worker.ts",
    "assets": {
        "directory": "./public",
        "binding": "ASSETS",
    },
}
