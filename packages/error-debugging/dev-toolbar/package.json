{
    "name": "@visulima/dev-toolbar",
    "version": "0.0.0",
    "description": "Devtools is a set of tools for building advanced devtools for your application",
    "keywords": [
        "visulima",
        "dev-toolbar"
    ],
    "homepage": "https://visulima.com/packages/dev-toolbar",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/error-debugging/dev-toolbar"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./vite": {
            "types": "./dist/vite-plugin.d.ts",
            "default": "./dist/vite-plugin.js"
        },
        "./client/overlay": {
            "types": "./dist/client/overlay.d.ts",
            "default": "./dist/client/overlay.js"
        },
        "./apps/a11y": {
            "types": "./dist/apps/a11y/index.d.ts",
            "default": "./dist/apps/a11y/index.js"
        },
        "./apps/module-graph": {
            "types": "./dist/apps/module-graph/index.d.ts",
            "default": "./dist/apps/module-graph/index.js"
        },
        "./apps/more": {
            "types": "./dist/apps/more/index.d.ts",
            "default": "./dist/apps/more/index.js"
        },
        "./apps/performance": {
            "types": "./dist/apps/performance/index.d.ts",
            "default": "./dist/apps/performance/index.js"
        },
        "./apps/seo": {
            "types": "./dist/apps/seo/index.d.ts",
            "default": "./dist/apps/seo/index.js"
        },
        "./apps/settings": {
            "types": "./dist/apps/settings/index.d.ts",
            "default": "./dist/apps/settings/index.js"
        },
        "./apps/timeline": {
            "types": "./dist/apps/timeline/index.d.ts",
            "default": "./dist/apps/timeline/index.js"
        },
        "./apps/vite-config": {
            "types": "./dist/apps/vite-config/index.d.ts",
            "default": "./dist/apps/vite-config/index.js"
        },
        "./toolbar": {
            "types": "./dist/toolbar/index.d.ts",
            "default": "./dist/toolbar/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint .",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=.prettierrc.cjs --check .",
        "lint:prettier:fix": "prettier --config=.prettierrc.cjs --write .",
        "lint:types": "tsc --noEmit --project tsconfig.json",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "axe-core": "^4.11.1",
        "clsx": "^2.1.1",
        "preact": "^10.28.4",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "1.4.0"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "^22.0.1",
        "@anolilab/semantic-release-pnpm": "5.0.0",
        "@anolilab/semantic-release-preset": "13.1.1",
        "@arethetypeswrong/cli": "^0.18.2",
        "@babel/core": "^7.29.0",
        "@babel/preset-react": "^7.28.5",
        "@eslint/css": "0.14.1",
        "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
        "@tailwindcss/node": "^4.2.1",
        "@tailwindcss/oxide": "^4.2.1",
        "@total-typescript/ts-reset": "^0.6.1",
        "@types/node": "25.3.2",
        "@visulima/packem": "2.0.0-alpha.51",
        "@vitest/coverage-v8": "^4.0.18",
        "@vitest/ui": "^4.0.18",
        "babel-plugin-transform-hook-names": "^1.0.2",
        "conventional-changelog-conventionalcommits": "9.1.0",
        "cssnano": "7.1.2",
        "esbuild": "^0.27.3",
        "eslint": "9.39.2",
        "lucide-static": "^0.575.0",
        "prettier": "^3.8.1",
        "publint": "^0.3.17",
        "rimraf": "^6.1.3",
        "secretlint": "11.3.1",
        "semantic-release": "^25.0.3",
        "tailwind-csstree": "0.1.4",
        "tailwindcss": "4.2.1",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    },
    "peerDependencies": {
        "vite": "^6 || ^7"
    },
    "engines": {
        "node": ">=22.21 <26"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
