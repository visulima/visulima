{
    "name": "@visulima/dev-toolbar",
    "version": "1.0.0-alpha.12",
    "description": "Devtools is a set of tools for building advanced devtools for your application",
    "keywords": [
        "visulima",
        "dev-toolbar"
    ],
    "homepage": "https://visulima.com/packages/dev-toolbar",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/error-debugging/dev-toolbar"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./vite": {
            "types": "./dist/vite-plugin.d.ts",
            "default": "./dist/vite-plugin.js"
        },
        "./client/overlay": {
            "types": "./dist/client/overlay.d.ts",
            "default": "./dist/client/overlay.js"
        },
        "./apps/a11y": {
            "types": "./dist/apps/a11y/index.d.ts",
            "default": "./dist/apps/a11y/index.js"
        },
        "./apps/assets": {
            "types": "./dist/apps/assets/index.d.ts",
            "default": "./dist/apps/assets/index.js"
        },
        "./apps/inspector": {
            "types": "./dist/apps/inspector/index.d.ts",
            "default": "./dist/apps/inspector/index.js"
        },
        "./apps/tailwind": {
            "types": "./dist/apps/tailwind/index.d.ts",
            "default": "./dist/apps/tailwind/index.js"
        },
        "./apps/module-graph": {
            "types": "./dist/apps/module-graph/index.d.ts",
            "default": "./dist/apps/module-graph/index.js"
        },
        "./apps/performance": {
            "types": "./dist/apps/performance/index.d.ts",
            "default": "./dist/apps/performance/index.js"
        },
        "./apps/seo": {
            "types": "./dist/apps/seo/index.d.ts",
            "default": "./dist/apps/seo/index.js"
        },
        "./apps/settings": {
            "types": "./dist/apps/settings/index.d.ts",
            "default": "./dist/apps/settings/index.js"
        },
        "./apps/timeline": {
            "types": "./dist/apps/timeline/index.d.ts",
            "default": "./dist/apps/timeline/index.js"
        },
        "./apps/annotations": {
            "types": "./dist/apps/annotations/index.d.ts",
            "default": "./dist/apps/annotations/index.js"
        },
        "./apps/vite-config": {
            "types": "./dist/apps/vite-config/index.d.ts",
            "default": "./dist/apps/vite-config/index.js"
        },
        "./mcp": {
            "types": "./dist/mcp/server.d.ts",
            "default": "./dist/mcp/server.js"
        },
        "./toolbar": {
            "types": "./dist/toolbar/index.d.ts",
            "default": "./dist/toolbar/index.js"
        },
        "./ui": {
            "types": "./dist/ui/index.d.ts",
            "default": "./dist/ui/index.js"
        },
        "./package.json": "./package.json"
    },
    "bin": {
        "visulima-dev-toolbar-mcp": "./bin/mcp.js"
    },
    "files": [
        "bin",
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint .",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit --project tsconfig.json",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@babel/generator": "catalog:prod",
        "@babel/parser": "catalog:prod",
        "@babel/traverse": "catalog:prod",
        "@floating-ui/dom": "catalog:prod",
        "launch-editor": "catalog:prod",
        "preact": "catalog:prod"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@babel/core": "catalog:dev",
        "@babel/preset-react": "catalog:frontend",
        "@babel/types": "catalog:dev",
        "@eslint/css": "catalog:lint",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@tailwindcss/node": "catalog:frontend",
        "@tailwindcss/oxide": "catalog:frontend",
        "@testing-library/jest-dom": "catalog:test",
        "@testing-library/preact": "catalog:test",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/babel__core": "catalog:types",
        "@types/babel__generator": "catalog:types",
        "@types/babel__traverse": "catalog:types",
        "@types/node": "catalog:types",
        "@visulima/packem": "catalog:dev",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "axe-core": "catalog:dev",
        "babel-plugin-transform-hook-names": "catalog:dev",
        "clsx": "catalog:prod",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "cssnano": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "eslint-plugin-zod": "3.5.4",
        "jsdom": "catalog:dev",
        "lucide-static": "catalog:icons",
        "prettier": "catalog:lint",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "tailwind-csstree": "catalog:dev",
        "tailwindcss": "catalog:style",
        "tw-animate-css": "catalog:dev",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test"
    },
    "peerDependencies": {
        "@modelcontextprotocol/sdk": "^1.0.0",
        "axe-core": "catalog:peer",
        "vite": "^6 || ^7 || ^8",
        "zod": "^3.0.0"
    },
    "peerDependenciesMeta": {
        "@modelcontextprotocol/sdk": {
            "optional": true
        },
        "axe-core": {
            "optional": true
        },
        "zod": {
            "optional": true
        }
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
