{
    "name": "@visulima/dev-toolbar",
    "version": "0.0.0",
    "description": "Devtools is a set of tools for building advanced devtools for your application",
    "keywords": [
        "visulima",
        "dev-toolbar"
    ],
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "homepage": "https://visulima.com/packages/dev-toolbar",
    "license": "MIT",
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./vite": {
            "types": "./dist/vite-plugin.d.ts",
            "default": "./dist/vite-plugin.js"
        },
        "./client/overlay": {
            "types": "./dist/client/overlay.d.ts",
            "default": "./dist/client/overlay.js"
        },
        "./apps": {
            "types": "./dist/apps/index.d.ts",
            "default": "./dist/apps/index.js"
        },
        "./toolbar": {
            "types": "./dist/toolbar/index.d.ts",
            "default": "./dist/toolbar/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/error-debugging/dev-toolbar"
    },
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint .",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=.prettierrc.cjs --check .",
        "lint:prettier:fix": "prettier --config=.prettierrc.cjs --write .",
        "lint:types": "tsc --noEmit --project tsconfig.json",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "tailwind-merge": "^2.5.5"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "^18.0.0",
        "@anolilab/semantic-release-pnpm": "3.2.2",
        "@anolilab/semantic-release-preset": "12.1.2",
        "@arethetypeswrong/cli": "^0.18.2",
        "@babel/core": "^7.28.5",
        "@babel/preset-react": "^7.28.5",
        "@eslint/css": "0.14.1",
        "@secretlint/secretlint-rule-preset-recommend": "^11.2.5",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/node": "^4.1.18",
        "@tailwindcss/oxide": "^4.1.18",
        "@total-typescript/ts-reset": "^0.6.1",
        "@types/node": "25.0.3",
        "@visulima/packem": "2.0.0-alpha.48",
        "@vitest/coverage-v8": "^4.0.16",
        "@vitest/ui": "^4.0.16",
        "babel-plugin-transform-hook-names": "^1.0.2",
        "conventional-changelog-conventionalcommits": "9.1.0",
        "cssnano": "7.1.2",
        "esbuild": "^0.27.2",
        "eslint": "9.39.2",
        "preact": "^10.28.1",
        "prettier": "^3.7.4",
        "publint": "^0.3.16",
        "rimraf": "^6.1.2",
        "secretlint": "11.2.5",
        "semantic-release": "^25.0.2",
        "tailwind-csstree": "0.1.4",
        "tailwindcss": "4.1.18",
        "typescript": "^5.9.3",
        "vitest": "^4.0.16"
    },
    "peerDependencies": {
        "vite": "^6 || ^7 || ^8"
    },
    "engines": {
        "node": ">=22.21 <=25.*"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
