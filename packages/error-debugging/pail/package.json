    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.server.d.ts",
                "default": "./dist/index.server.js"
            },
            "browser": "./dist/index.browser.js"
        },
        "./browser": {
            "types": "./dist/index.browser.d.ts",
            "default": "./dist/index.browser.js"
        },
        "./server": {
            "types": "./dist/index.server.d.ts",
            "default": "./dist/index.server.js"
        },
        "./processor/redact": {
            "types": "./dist/processor/redact-processor.d.ts",
            "default": "./dist/processor/redact-processor.js"
        },
        "./processor/message-formatter": {
            "types": "./dist/processor/message-formatter-processor.d.ts",
            "default": "./dist/processor/message-formatter-processor.js"
        },
        "./processor/caller": {
            "types": "./dist/processor/caller/caller-processor.d.ts",
            "default": "./dist/processor/caller/caller-processor.js"
        },
        "./processor/opentelemetry": {
            "types": "./dist/processor/opentelemetry-processor.d.ts",
            "default": "./dist/processor/opentelemetry-processor.js"
        },
        "./processor/sampling": {
            "types": "./dist/processor/sampling-processor.d.ts",
            "default": "./dist/processor/sampling-processor.js"
        },
        "./processor/environment": {
            "types": "./dist/processor/environment-processor.d.ts",
            "default": "./dist/processor/environment-processor.js"
        },
        "./error": {
            "types": "./dist/error.d.ts",
            "default": "./dist/error.js"
        },
        "./reporter/file": {
            "types": "./dist/reporter/file/json-file-reporter.d.ts",
            "default": "./dist/reporter/file/json-file-reporter.js"
        },
        "./server/reporter/json": {
            "import": {
                "types": "./dist/reporter/json/index.d.ts",
                "default": "./dist/reporter/json/index.js"
            }
        },
        "./browser/reporter/json": {
            "import": {
                "types": "./dist/reporter/json/index.browser.d.ts",
                "default": "./dist/reporter/json/index.browser.js"
            }
        },
        "./reporter/json": {
            "import": {
                "types": "./dist/reporter/json/index.d.ts",
                "default": "./dist/reporter/json/index.js"
            },
            "browser": "./dist/reporter/json/index.browser.js"
        },
        "./server/reporter/pretty": {
            "import": {
                "types": "./dist/reporter/pretty/index.d.ts",
                "default": "./dist/reporter/pretty/index.js"
            }
        },
        "./browser/reporter/pretty": {
            "import": {
                "types": "./dist/reporter/pretty/index.browser.d.ts",
                "default": "./dist/reporter/pretty/index.browser.js"
            }
        },
        "./reporter/pretty": {
            "import": {
                "types": "./dist/reporter/pretty/index.d.ts",
                "default": "./dist/reporter/pretty/index.js"
            },
            "browser": "./dist/reporter/pretty/index.browser.js"
        },
        "./reporter/simple": {
            "types": "./dist/reporter/simple/simple-reporter.server.d.ts",
            "default": "./dist/reporter/simple/simple-reporter.server.js"
        },
        "./reporter/abstract-http": {
            "types": "./dist/reporter/http/abstract-http-reporter.d.ts",
            "default": "./dist/reporter/http/abstract-http-reporter.js"
        },
        "./reporter/http": {
            "import": {
                "types": "./dist/reporter/http/http-reporter.d.ts",
                "default": "./dist/reporter/http/http-reporter.js"
            },
            "edge-light": {
                "types": "./dist/reporter/http/http-reporter.edge-light.d.ts",
                "default": "./dist/reporter/http/http-reporter.edge-light.js"
            },
            "browser": {
                "types": "./dist/reporter/http/http-reporter.d.ts",
                "default": "./dist/reporter/http/http-reporter.js"
            }
        },
        "./object-tree": {
            "types": "./dist/object-tree.d.ts",
            "default": "./dist/object-tree.js"
        },
        "./wide-event": {
            "types": "./dist/wide-event.d.ts",
            "default": "./dist/wide-event.js"
        },
        "./middleware/express": {
            "types": "./dist/middleware/express.d.ts",
            "default": "./dist/middleware/express.js"
        },
        "./middleware/fastify": {
            "types": "./dist/middleware/fastify.d.ts",
            "default": "./dist/middleware/fastify.js"
        },
        "./middleware/hono": {
            "types": "./dist/middleware/hono.d.ts",
            "default": "./dist/middleware/hono.js"
        },
        "./middleware/elysia": {
            "types": "./dist/middleware/elysia.d.ts",
            "default": "./dist/middleware/elysia.js"
        },
        "./middleware/sveltekit": {
            "types": "./dist/middleware/sveltekit.d.ts",
            "default": "./dist/middleware/sveltekit.js"
        },
        "./middleware/next": {
            "types": "./dist/middleware/next/handler.d.ts",
            "default": "./dist/middleware/next/handler.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**",
        "README.md",
        "CHANGELOG.md",
        "LICENSE.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "fallow:audit": "fallow audit",
        "fallow:dead-code": "fallow dead-code",
        "fallow:health": "fallow health --report-only",
        "lint:attw": "attw --pack --profile esm-only",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@visulima/colorize": "2.0.0-alpha.14",
        "@visulima/interactive-manager": "1.0.0-alpha.5"
    },
