{
    "name": "@visulima/workflow",
    "version": "1.0.0",
    "description": "A reusable, ESM-only, edge-ready durable workflow engine: code-first workflows with resumable steps, delays and external-event waits, backed by a pluggable store",
    "keywords": [
        "cloudflare",
        "cron",
        "durable",
        "durable-execution",
        "edge",
        "long-running",
        "orchestration",
        "resumable",
        "saga",
        "scheduler",
        "standard-schema",
        "state-machine",
        "step",
        "visulima",
        "workflow",
        "xstate"
    ],
    "homepage": "https://visulima.com/packages/workflow",
    "bugs": "https://github.com/visulima/visulima/issues",
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/workflow/workflow"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./store/memory": {
            "types": "./dist/store/memory-store.d.ts",
            "default": "./dist/store/memory-store.js"
        },
        "./store/unstorage": {
            "types": "./dist/store/unstorage-store.d.ts",
            "default": "./dist/store/unstorage-store.js"
        },
        "./store/sql": {
            "types": "./dist/store/sql-store.d.ts",
            "default": "./dist/store/sql-store.js"
        },
        "./store/durable-object": {
            "types": "./dist/store/durable-object-store.d.ts",
            "default": "./dist/store/durable-object-store.js"
        },
        "./store/redis": {
            "types": "./dist/store/redis-store.d.ts",
            "default": "./dist/store/redis-store.js"
        },
        "./package.json": "./package.json"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "fallow:audit": "fallow audit",
        "fallow:dead-code": "fallow dead-code",
        "fallow:health": "fallow health --report-only",
        "lint:attw": "attw --pack --profile esm-only",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit --project tsconfig.json",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@standard-schema/spec": "^1.1.0",
        "croner": "^10.0.1",
        "xstate": "^5.32.3"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/prettier-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@electric-sql/pglite": "0.5.4",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/node": "catalog:types",
        "@visulima/packem": "catalog:dev",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "eslint-plugin-zod": "4.7.0",
        "fallow": "catalog:lint",
        "mysql-memory-server": "1.14.1",
        "mysql2": "^3.22.5",
        "prettier": "catalog:lint",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "typescript": "catalog:tsc",
        "unstorage": "^1.17.5",
        "vitest": "catalog:test",
        "zod": "catalog:utils"
    },
    "peerDependencies": {
        "unstorage": "^1.13.0"
    },
    "peerDependenciesMeta": {
        "unstorage": {
            "optional": true
        }
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    }
}
