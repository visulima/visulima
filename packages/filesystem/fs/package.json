{
    "name": "@visulima/fs",
    "version": "5.0.0-alpha.8",
    "description": "Human friendly file system utilities for Node.js",
    "keywords": [
        "anolilab",
        "detect-newline",
        "dir",
        "directory",
        "eol",
        "empty-dir",
        "ensure",
        "ensure-file",
        "ensure-dir",
        "ensure-link",
        "ensure-symlink",
        "file",
        "files",
        "filesystem",
        "find",
        "find-up",
        "findup",
        "folder",
        "fs",
        "fs-safe",
        "look",
        "look-up",
        "json",
        "read-json",
        "match",
        "package",
        "parent",
        "parents",
        "path",
        "read",
        "read-file",
        "read-yaml",
        "resolve",
        "safe",
        "search",
        "std",
        "standard",
        "up",
        "visulima",
        "walk",
        "walking",
        "write",
        "write-dir",
        "write-file",
        "write-safe",
        "yaml",
        "size",
        "brotli",
        "gzip"
    ],
    "homepage": "https://visulima.com/packages/fs/",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/filesystem/fs"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./utils": {
            "types": "./dist/utils.d.ts",
            "default": "./dist/utils.js"
        },
        "./error": {
            "types": "./dist/error.d.ts",
            "default": "./dist/error.js"
        },
        "./yaml": {
            "types": "./dist/yaml.d.ts",
            "default": "./dist/yaml.js"
        },
        "./size": {
            "types": "./dist/size.d.ts",
            "default": "./dist/size.js"
        },
        "./eol": {
            "types": "./dist/eol.d.ts",
            "default": "./dist/eol.js"
        },
        "./glob": {
            "types": "./dist/glob.d.ts",
            "default": "./dist/glob.js"
        },
        "./glob-parent": {
            "types": "./dist/glob-parent.d.ts",
            "default": "./dist/glob-parent.js"
        },
        "./is-glob": {
            "types": "./dist/is-glob.d.ts",
            "default": "./dist/is-glob.js"
        },
        "./match": {
            "types": "./dist/match.d.ts",
            "default": "./dist/match.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**",
        "README.md",
        "CHANGELOG.md",
        "LICENSE.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@visulima/path": "3.0.0-alpha.9",
        "type-fest": "catalog:prod"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/prettier-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@types/glob-parent": "^5.1.3",
        "@types/is-glob": "^4.0.4",
        "@types/node": "catalog:types",
        "@types/picomatch": "^4.0.3",
        "@visulima/error": "6.0.0-alpha.9",
        "@visulima/packem": "catalog:dev",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "detect-indent": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "fast-safe-stringify": "catalog:dev",
        "glob-parent": "^6.0.2",
        "is-fs-case-sensitive": "catalog:dev",
        "is-glob": "^4.0.3",
        "picomatch": "^4.0.4",
        "prettier": "catalog:lint",
        "publint": "catalog:dev",
        "redos-detector": "catalog:dev",
        "rimraf": "catalog:node",
        "safe-regex2": "catalog:dev",
        "semantic-release": "catalog:cli",
        "tempy": "catalog:dev",
        "tinyglobby": "^0.2.16",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test",
        "yaml": "catalog:dev"
    },
    "peerDependencies": {
        "yaml": "catalog:peer"
    },
    "peerDependenciesMeta": {
        "yaml": {
            "optional": true
        }
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    },
    "os": [
        "darwin",
        "linux",
        "win32"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
