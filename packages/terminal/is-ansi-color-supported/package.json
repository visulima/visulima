{
    "name": "@visulima/is-ansi-color-supported",
    "version": "3.0.0-alpha.14",
    "description": "Detect whether a terminal or browser supports ansi colors.",
    "keywords": [
        "256",
        "FORCE_COLOR",
        "NO_COLOR",
        "anolilab",
        "ansi",
        "ansi-colors",
        "capability",
        "cli",
        "color",
        "colorize",
        "colors",
        "colour",
        "command-line",
        "console",
        "detect",
        "edge",
        "next.js",
        "nextjs",
        "shell",
        "style",
        "styles",
        "support",
        "supports",
        "terminal",
        "truecolor",
        "tty",
        "visulima",
        "xterm"
    ],
    "homepage": "https://visulima.com/packages/is-ansi-color-supported/",
    "bugs": "https://github.com/visulima/visulima/issues",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/terminal/is-ansi-color-supported"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "edge-light": {
                "types": "./dist/is-color-supported.edge-light.d.ts",
                "default": "./dist/is-color-supported.edge-light.js"
            },
            "browser": {
                "types": "./dist/is-color-supported.browser.d.ts",
                "default": "./dist/is-color-supported.browser.js"
            },
            "default": {
                "types": "./dist/is-color-supported.server.d.ts",
                "default": "./dist/is-color-supported.server.js"
            }
        },
        "./browser": {
            "types": "./dist/is-color-supported.browser.d.ts",
            "default": "./dist/is-color-supported.browser.js"
        },
        "./edge-light": {
            "types": "./dist/is-color-supported.edge-light.d.ts",
            "default": "./dist/is-color-supported.edge-light.js"
        },
        "./package.json": "./package.json"
    },
    "module": "dist/is-color-supported.server.js",
    "browser": "dist/is-color-supported.browser.js",
    "types": "dist/is-color-supported.server.d.ts",
    "typesVersions": {
        ">=5.0": {
            ".": [
                "./dist/is-color-supported.edge-light.d.ts",
                "./dist/is-color-supported.browser.d.ts",
                "./dist/is-color-supported.server.d.ts"
            ],
            "edge-light": [
                "./dist/is-color-supported.edge-light.d.ts"
            ],
            "browser": [
                "./dist/is-color-supported.browser.d.ts"
            ]
        }
    },
    "files": [
        "dist/**",
        "README.md",
        "CHANGELOG.md",
        "LICENSE.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "fallow:audit": "fallow audit",
        "fallow:dead-code": "fallow dead-code",
        "fallow:health": "fallow health --report-only",
        "lint:attw": "attw --pack --profile esm-only",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/prettier-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@types/node": "catalog:types",
        "@visulima/packem": "catalog:dev",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "fallow": "catalog:lint",
        "prettier": "catalog:lint",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test"
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
