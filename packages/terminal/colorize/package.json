{
    "name": "@visulima/colorize",
    "version": "2.0.0-alpha.15",
    "description": "Terminal and Console string styling done right.",
    "keywords": [
        "256",
        "FORCE_COLOR",
        "NO_COLOR",
        "anolilab",
        "ansi",
        "ansi-colors",
        "blue",
        "browser",
        "chalk",
        "chrome",
        "cli",
        "color",
        "colorette",
        "colorize",
        "colors",
        "colors.js",
        "colour",
        "command-line",
        "console",
        "cyan",
        "firefox",
        "formatting",
        "gradient",
        "gradients",
        "green",
        "kleur",
        "log",
        "logging",
        "magenta",
        "picocolors",
        "red",
        "rgb",
        "shell",
        "string",
        "strip-color",
        "style",
        "styles",
        "tagged template",
        "tagged template literal",
        "tagged template string",
        "tagged-template",
        "template",
        "template-string",
        "templates",
        "terminal",
        "text",
        "truecolor",
        "tty",
        "visulima",
        "xterm",
        "yellow"
    ],
    "homepage": "https://visulima.com/packages/colorize/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/terminal/colorize"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "browser": {
                "types": "./dist/index.browser.d.ts",
                "default": "./dist/index.browser.js"
            },
            "edge-light": {
                "types": "./dist/index.server.d.ts",
                "default": "./dist/index.server.js"
            },
            "default": {
                "types": "./dist/index.server.d.ts",
                "default": "./dist/index.server.js"
            }
        },
        "./browser": {
            "types": "./dist/index.browser.d.ts",
            "default": "./dist/index.browser.js"
        },
        "./template": {
            "types": "./dist/template.d.ts",
            "default": "./dist/template.js"
        },
        "./gradient": {
            "types": "./dist/gradient.d.ts",
            "default": "./dist/gradient.js"
        },
        "./utils": {
            "types": "./dist/utils.d.ts",
            "default": "./dist/utils.js"
        },
        "./package.json": "./package.json"
    },
    "module": "dist/index.server.js",
    "types": "dist/index.server.d.ts",
    "typesVersions": {
        ">=5.0": {
            ".": [
                "./dist/index.browser.d.ts",
                "./dist/index.server.d.ts"
            ],
            "browser": [
                "./dist/index.browser.d.ts"
            ],
            "template": [
                "./dist/template.d.ts"
            ],
            "gradient": [
                "./dist/gradient.d.ts"
            ],
            "utils": [
                "./dist/utils.d.ts"
            ]
        }
    },
    "files": [
        "dist/**",
        "README.md",
        "CHANGELOG.md",
        "LICENSE.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "fallow:audit": "fallow audit",
        "fallow:dead-code": "fallow dead-code",
        "fallow:health": "fallow health --report-only",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@visulima/is-ansi-color-supported": "3.0.0-alpha.14"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/prettier-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@rushstack/eslint-plugin-security": "catalog:lint",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/node": "catalog:types",
        "@visulima/packem": "catalog:dev",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "ansi-regex": "catalog:dev",
        "ansi-styles": "catalog:dev",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "fallow": "catalog:lint",
        "prettier": "catalog:lint",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "rollup": "catalog:build",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test"
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    },
    "os": [
        "darwin",
        "linux",
        "win32"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
