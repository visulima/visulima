{
    "name": "@visulima/tabular",
    "version": "4.0.0-alpha.10",
    "description": "Create beautiful ASCII tables and grids with customizable borders, padding, and alignment. Supports Unicode, colors, and ANSI escape codes.",
    "keywords": [
        "cli",
        "table",
        "grid",
        "tabular",
        "terminal",
        "console",
        "ascii",
        "unicode",
        "alignment",
        "ansi",
        "visulima"
    ],
    "homepage": "https://visulima.com/packages/tabular",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/terminal/tabular"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./style": {
            "types": "./dist/style.d.ts",
            "default": "./dist/style.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "CHANGELOG.md",
        "README.md",
        "dist"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit",
        "lint:types:tabular": "pnpm --filter \"tabular\" run lint:types",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:coverage:tabular": "pnpm --filter \"tabular\" run test:coverage",
        "test:tabular": "pnpm --filter \"tabular\" run test",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:ui:tabular": "pnpm --filter \"tabular\" run test:ui",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/prettier-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/node": "catalog:types",
        "@visulima/colorize": "2.0.0-alpha.9",
        "@visulima/packem": "catalog:dev",
        "@visulima/string": "3.0.0-alpha.10",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "ansi-regex": "catalog:dev",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "jiti": "catalog:dev",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "terminal-size": "catalog:dev",
        "type-fest": "catalog:dev",
        "typedoc": "catalog:dev",
        "typedoc-plugin-markdown": "catalog:dev",
        "typedoc-plugin-rename-defaults": "catalog:dev",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test"
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
