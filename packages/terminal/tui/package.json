{
    "name": "@visulima/tui",
    "version": "1.0.0-alpha.8",
    "description": "React-based TUI library powered by a native Rust diff engine, drop-in Ink-compatible API",
    "keywords": [
        "cli",
        "ink",
        "napi",
        "react",
        "rust",
        "terminal",
        "tui",
        "visulima"
    ],
    "homepage": "https://visulima.com/packages/tui",
    "bugs": {
        "url": "https://github.com/visulima/visulima/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/visulima/visulima.git",
        "directory": "packages/terminal/tui"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": [
        "./dist/ink/**",
        "./dist/react/**",
        "./index.js"
    ],
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/ink/index.d.ts",
            "default": "./dist/ink/index.js"
        },
        "./core": {
            "types": "./dist/core/index.d.ts",
            "default": "./dist/core/index.js"
        },
        "./react": {
            "types": "./dist/react/index.d.ts",
            "default": "./dist/react/index.js"
        },
        "./test": {
            "types": "./dist/testing/index.d.ts",
            "default": "./dist/testing/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**",
        "index.js",
        "README.md",
        "CHANGELOG.md",
        "LICENSE.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:native": "napi build --platform --release --esm --manifest-path native/Cargo.toml --output-dir . --js index.js",
        "build:native:debug": "napi build --platform --esm --manifest-path native/Cargo.toml --output-dir . --js index.js",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache *.node",
        "dev": "pnpm run build --watch",
        "example": "NODE_NO_WARNINGS=1 node --import=tsx",
        "lint:attw": "attw --pack",
        "lint:eslint": "eslint . --cache --concurrency auto",
        "lint:eslint:fix": "eslint . --cache --concurrency auto --fix",
        "lint:package-json": "publint --strict",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:types": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@shikijs/langs": "catalog:prod",
        "@shikijs/themes": "catalog:dev",
        "@visulima/ansi": "4.0.0-alpha.13",
        "@visulima/colorize": "2.0.0-alpha.10",
        "@visulima/string": "3.0.0-alpha.11",
        "@visulima/tabular": "4.0.0-alpha.11",
        "cfonts": "3.3.1",
        "diff": "catalog:prod",
        "eventemitter3": "catalog:prod",
        "marked": "catalog:dev",
        "patch-console": "catalog:prod",
        "scheduler": "catalog:prod",
        "shiki": "catalog:syntax",
        "ws": "catalog:prod",
        "yoga-layout": "catalog:prod",
        "yoga-layout-prebuilt": "catalog:prod"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "catalog:lint",
        "@anolilab/prettier-config": "catalog:lint",
        "@anolilab/semantic-release-pnpm": "catalog:dev",
        "@anolilab/semantic-release-preset": "catalog:dev",
        "@arethetypeswrong/cli": "catalog:dev",
        "@eslint-react/eslint-plugin": "catalog:lint",
        "@napi-rs/cli": "catalog:dev",
        "@secretlint/secretlint-rule-preset-recommend": "catalog:lint",
        "@semantic-release/exec": "catalog:dev",
        "@total-typescript/ts-reset": "catalog:dev",
        "@types/node": "catalog:types",
        "@types/react": "catalog:types",
        "@types/react-reconciler": "catalog:types",
        "@types/scheduler": "catalog:types",
        "@types/stack-utils": "catalog:types",
        "@types/ws": "catalog:types",
        "@visulima/boxen": "3.0.0-alpha.10",
        "@visulima/packem": "catalog:dev",
        "@visulima/spinner": "1.0.0-alpha.1",
        "@vitest/coverage-v8": "catalog:test",
        "@vitest/ui": "catalog:test",
        "@xterm/headless": "catalog:dev",
        "auto-bind": "catalog:prod",
        "cli-boxes": "catalog:prod",
        "code-excerpt": "catalog:prod",
        "conventional-changelog-conventionalcommits": "catalog:dev",
        "delay": "catalog:dev",
        "es-toolkit": "catalog:prod",
        "esbuild": "catalog:build",
        "eslint": "catalog:lint",
        "eslint-plugin-jsx-a11y": "catalog:lint",
        "eslint-plugin-react": "catalog:lint",
        "eslint-plugin-react-hooks": "catalog:lint",
        "eslint-plugin-react-perf": "catalog:lint",
        "eslint-plugin-react-refresh": "catalog:lint",
        "eslint-plugin-react-you-might-not-need-an-effect": "catalog:lint",
        "eslint-plugin-validate-jsx-nesting": "catalog:lint",
        "is-in-ci": "catalog:prod",
        "node-pty": "catalog:dev",
        "prettier": "catalog:lint",
        "publint": "catalog:dev",
        "rimraf": "catalog:node",
        "secretlint": "catalog:lint",
        "semantic-release": "catalog:cli",
        "signal-exit": "catalog:prod",
        "stack-utils": "catalog:prod",
        "terminal-size": "catalog:dev",
        "tsx": "catalog:dev",
        "type-fest": "catalog:prod",
        "typescript": "catalog:tsc",
        "vitest": "catalog:test"
    },
    "peerDependencies": {
        "react": ">=19.2.6",
        "react-devtools-core": ">=7.0.1",
        "react-reconciler": ">=0.33.0"
    },
    "peerDependenciesMeta": {
        "react-devtools-core": {
            "optional": true
        }
    },
    "optionalDependencies": {
        "@visulima/tui-binding-darwin-arm64": "workspace:*",
        "@visulima/tui-binding-darwin-x64": "workspace:*",
        "@visulima/tui-binding-linux-arm64-gnu": "workspace:*",
        "@visulima/tui-binding-linux-arm64-musl": "workspace:*",
        "@visulima/tui-binding-linux-x64-gnu": "workspace:*",
        "@visulima/tui-binding-linux-x64-musl": "workspace:*",
        "@visulima/tui-binding-win32-arm64-msvc": "workspace:*",
        "@visulima/tui-binding-win32-x64-msvc": "workspace:*"
    },
    "engines": {
        "node": "^22.14.0 || >=24.10.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "napi": {
        "binaryName": "tui-native",
        "packageName": "@visulima/tui-binding",
        "targets": [
            "x86_64-apple-darwin",
            "aarch64-apple-darwin",
            "x86_64-unknown-linux-gnu",
            "x86_64-unknown-linux-musl",
            "aarch64-unknown-linux-gnu",
            "aarch64-unknown-linux-musl",
            "x86_64-pc-windows-msvc",
            "aarch64-pc-windows-msvc"
        ]
    }
}
