{
    "name": "www",
    "version": "0.0.0",
    "private": true,
    "description": "Visulima main website",
    "type": "module",
    "scripts": {
        "build": "node scripts/generate-packages.js && node scripts/copy-package-docs.js && node scripts/copy-install-scripts.js && node scripts/fetch-stats.js && vite build",
        "copy-docs": "node scripts/copy-package-docs.js",
        "dev": "node scripts/generate-packages.js && node scripts/copy-package-docs.js && node scripts/copy-install-scripts.js && vite dev",
        "lint:eslint": "eslint src",
        "lint:eslint:fix": "eslint src --fix",
        "lint:prettier": "prettier --config=prettier.config.js --check .",
        "lint:prettier:fix": "prettier --config=prettier.config.js --write .",
        "lint:secrets": "secretlint **/*",
        "lint:types": "tsc --project tsconfig.json --noEmit",
        "serve": "vite preview",
        "start": "node .output/server/index.mjs"
    },
    "dependencies": {
        "@babel/core": "catalog:dev",
        "@fuma-comment/react": "catalog:frontend",
        "@fumadocs/mdx-remote": "catalog:prod",
        "@icons-pack/react-simple-icons": "catalog:icons",
        "@radix-ui/react-icons": "catalog:icons",
        "@radix-ui/react-presence": "catalog:frontend",
        "@radix-ui/react-slot": "catalog:frontend",
        "@react-three/fiber": "catalog:frontend",
        "@rolldown/plugin-babel": "catalog:build",
        "@tailwindcss/vite": "catalog:build",
        "@tanstack/react-router": "catalog:frontend",
        "@tanstack/react-router-devtools": "catalog:frontend",
        "@tanstack/react-start": "catalog:frontend",
        "@tanstack/react-virtual": "catalog:frontend",
        "@types/babel__core": "catalog:types",
        "@types/mdx": "catalog:types",
        "@types/node": "catalog:types",
        "@types/react": "catalog:types",
        "@types/react-dom": "catalog:types",
        "@types/three": "catalog:types",
        "@unpic/react": "catalog:frontend",
        "@vidstack/react": "catalog:frontend",
        "@vitejs/plugin-react": "catalog:build",
        "babel-plugin-react-compiler": "catalog:frontend",
        "class-variance-authority": "catalog:prod",
        "clsx": "catalog:prod",
        "cmdk": "catalog:prod",
        "date-fns": "catalog:prod",
        "embla-carousel-react": "catalog:utils",
        "fast-glob": "catalog:node",
        "fumadocs-core": "catalog:prod",
        "fumadocs-mdx": "catalog:prod",
        "fumadocs-twoslash": "catalog:prod",
        "fumadocs-ui": "catalog:frontend",
        "gray-matter": "catalog:prod",
        "lucide-react": "catalog:icons",
        "lucide-static": "catalog:icons",
        "media-icons": "catalog:icons",
        "motion": "catalog:frontend",
        "next-themes": "catalog:prod",
        "posthog-js": "catalog:prod",
        "radix-ui": "catalog:frontend",
        "react": "catalog:frontend",
        "react-dom": "catalog:frontend",
        "react-hook-inview": "catalog:frontend",
        "react-icon-cloud": "catalog:icons",
        "react-remove-scroll": "catalog:frontend",
        "shiki": "catalog:syntax",
        "tailwind-merge": "catalog:prod",
        "tailwindcss": "catalog:style",
        "tailwindcss-animate": "catalog:style",
        "three": "catalog:frontend",
        "typescript": "catalog:tsc",
        "unplugin-fonts": "catalog:build",
        "use-count-up": "catalog:utils",
        "vite": "catalog:build",
        "vite-imagetools": "catalog:build",
        "vite-plugin-svgr": "catalog:build",
        "zod": "catalog:utils"
